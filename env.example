# Marker (Interfax / Zakupki) — учётные данные.
# Реальные значения положить в .env (этот файл должен быть в .gitignore).
# НИКОГДА не коммитить .env в репозиторий.

# Веб-аккаунт (для логина через accounts.marker-zakupki.ru)
MARKER_USERNAME=
MARKER_PASSWORD=

# Сессионная кука (получается после логина в браузере, недолговечная — обновлять)
# Скопировать значение SmTicketCookie из DevTools → Application → Cookies
MARKER_SESSION_TICKET=

# Базовые URL
MARKER_API_BASE=https://analytics.marker-zakupki.ru/api
MARKER_AUTH_BASE=https://accounts.marker-zakupki.ru
MARKER_HOME_REFERER=https://analytics.marker-zakupki.ru/Home

# Если получим официальный программный API ("Шлюз Торги" от Интерфакса):
# MARKER_WEBAPI_KEY=
# MARKER_WEBAPI_BASE=

# === LLM провайдер ===
# По умолчанию используется openai (см. LLM_PROVIDER ниже).
# OpenAI:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Альтернатива — Anthropic (Claude):
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
# Какой провайдер использовать (openai | anthropic):
LLM_PROVIDER=openai
